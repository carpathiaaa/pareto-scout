# Copy to web/.env.local and fill in. Only NEXT_PUBLIC_ vars reach the browser.

# --- Supabase (browser, read + status writes via RLS) ---
# Same Supabase project as the Python agents, but the ANON key (never service-role).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only secrets (used in API routes, NEVER prefixed NEXT_PUBLIC_) ---
# The send route writes status 'sent'/'failed', which the anon key is forbidden to
# do (migration 004), so it needs the service-role key server-side.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (email send, server-side only) ---
RESEND_API_KEY=
# Free tier without a verified domain: from must be onboarding@resend.dev and the
# recipient must be your Resend account email.
OUTREACH_FROM_EMAIL=onboarding@resend.dev
# POC guardrail: ALL sends go here, never to the real scraped contact. Must match
# your Resend account email for free-tier delivery to actually arrive.
OUTREACH_TEST_INBOX=
