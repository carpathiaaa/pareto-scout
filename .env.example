# Copy to .env and fill in. Never commit .env.
# Loaded through shared/utils.get_env — do not read os.environ ad hoc.

# --- Supabase (Python: agents + api) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (Next.js: web) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- LLM (provider-agnostic, Groq today) ---
# To switch providers later, change these three values only.
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# --- Email (Resend) ---
RESEND_API_KEY=
OUTREACH_FROM_EMAIL=

# --- Notifications (Slack) ---
SLACK_WEBHOOK_URL=

# --- Agent: lead ---
# mock (default) reads fixtures and spends zero credits. Set to "live" only to
# validate against real Apollo/Hunter — each live run spends scarce free-tier credits.
LEAD_SOURCE_MODE=mock
APOLLO_API_KEY=
HUNTER_API_KEY=

# --- Agent: expert ---
# mock (default) reads fixtures and spends zero credits. Set to "live" only to
# validate against real SerpAPI — each live run spends one search (free tier ~100/mo).
EXPERT_SOURCE_MODE=mock
SERPAPI_KEY=

# --- Agent: jobs (optional, for authenticated Reddit reads) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
